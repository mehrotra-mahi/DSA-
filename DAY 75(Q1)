#include <stdio.h>
#include <stdlib.h>

#define MAX 1000

int maxLen(int arr[], int n) {
    int prefixSum = 0, maxLength = 0;

    // Hash map (array) to store first occurrence of prefix sums
    // Initialize all values as -1
    int hash[2 * MAX + 1];
    for (int i = 0; i < 2 * MAX + 1; i++)
        hash[i] = -1;

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        // Case 1: If prefix sum is zero
        if (prefixSum == 0)
            maxLength = i + 1;

        // Shift index to handle negative sums
        int index = prefixSum + MAX;

        // Case 2: If prefix sum seen before
        if (hash[index] != -1) {
            int length = i - hash[index];
            if (length > maxLength)
                maxLength = length;
        } else {
            // Store first occurrence
            hash[index] = i;
        }
    }

    return maxLength;
}

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("%d\n", maxLen(arr, n));
    return 0;
}
