class Deque:
    def __init__(self):
        self.d = []

    def push_front(self, value):
        self.d.insert(0, value)

    def push_back(self, value):
        self.d.append(value)

    def pop_front(self):
        if self.empty():
            return -1
        return self.d.pop(0)

    def pop_back(self):
        if self.empty():
            return -1
        return self.d.pop()

    def front(self):
        if self.empty():
            return -1
        return self.d[0]

    def back(self):
        if self.empty():
            return -1
        return self.d[-1]

    def empty(self):
        return len(self.d) == 0

    def size(self):
        return len(self.d)

    def clear(self):
        self.d.clear()

    def reverse(self):
        self.d.reverse()

    def sort(self):
        self.d.sort()

    def display(self):
        print(self.d)
