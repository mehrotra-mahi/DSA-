#include <stdio.h>

int postIndex;

// Function to find index of value in inorder array
int search(int inorder[], int start, int end, int value) {
    for (int i = start; i <= end; i++) {
        if (inorder[i] == value)
            return i;
    }
    return -1;
}

// Function to construct tree and print preorder
void buildPreorder(int inorder[], int postorder[], int start, int end) {
    if (start > end)
        return;

    // Get root from postorder
    int root = postorder[postIndex--];

    // Print root (Preorder)
    printf("%d ", root);

    // Find root in inorder
    int index = search(inorder, start, end, root);

    // Build right subtree first
    buildPreorder(inorder, postorder, index + 1, end);

    // Build left subtree
    buildPreorder(inorder, postorder, start, index - 1);
}

int main() {
    int n;
    scanf("%d", &n);

    int inorder[n], postorder[n];

    for (int i = 0; i < n; i++)
        scanf("%d", &inorder[i]);

    for (int i = 0; i < n; i++)
        scanf("%d", &postorder[i]);

    postIndex = n - 1;

    buildPreorder(inorder, postorder, 0, n - 1);

    return 0;
}
